#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:?commit message file required}"
first_line="$(head -n 1 "$msg_file")"

if ! printf '%s' "$first_line" | grep -Eq '^(feat|fix|docs|chore|refactor|test|ops|data|deploy)(\([a-z0-9._-]+\))?: .+'; then
  echo "Commit message must use Conventional Commits, e.g. feat: add editor shell" >&2
  exit 1
fi
