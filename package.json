{
  "name": "openphoto-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based photo editor with WASM imaging tools and local WebGPU AI features.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview --host 0.0.0.0",
    "serve:dist": "vite preview --host 0.0.0.0 --strictPort --port 4173",
    "lint": "eslint . --max-warnings 0",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.2",
    "comlink": "^4.4.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.468.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.2.1",
    "vitest": "^4.1.5"
  }
}
